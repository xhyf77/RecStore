{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recstore.local/schema/recstore_config.schema.json",
  "title": "RecStore Config Schema",
  "description": "Schema for recstore_config.json. Includes structural checks, keyword(enum) checks, and conditional checks for HYBRID mode.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "cache_ps",
    "distributed_client",
    "client"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema URI/path for IDE auto-discovery."
    },
    "cache_ps": {
      "type": "object",
      "description": "Parameter server runtime and storage settings.",
      "additionalProperties": true,
      "required": [
        "ps_type",
        "max_batch_keys_size",
        "num_threads",
        "num_shards",
        "servers",
        "base_kv_config"
      ],
      "properties": {
        "ps_type": {
          "type": "string",
          "enum": [
            "GRPC",
            "BRPC"
          ],
          "description": "Keyword check: transport type must be one of GRPC or BRPC."
        },
        "max_batch_keys_size": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum key count per batch request on server side."
        },
        "num_threads": {
          "type": "integer",
          "minimum": 1,
          "description": "Server worker threads."
        },
        "num_shards": {
          "type": "integer",
          "minimum": 1,
          "description": "Shard count. Should align with servers length."
        },
        "servers": {
          "type": "array",
          "minItems": 1,
          "description": "Server endpoint list.",
          "items": {
            "$ref": "#/$defs/serverNode"
          }
        },
        "base_kv_config": {
          "$ref": "#/$defs/baseKvConfig"
        }
      }
    },
    "distributed_client": {
      "type": "object",
      "description": "Distributed client routing and request split settings.",
      "additionalProperties": true,
      "required": [
        "num_shards",
        "hash_method",
        "servers"
      ],
      "properties": {
        "num_shards": {
          "type": "integer",
          "minimum": 1,
          "description": "Distributed shard count. Should align with cache_ps.num_shards."
        },
        "hash_method": {
          "type": "string",
          "enum": [
            "city_hash",
            "simple_mod"
          ],
          "description": "Keyword check: hash strategy."
        },
        "max_keys_per_request": {
          "type": "integer",
          "minimum": 1,
          "default": 500,
          "description": "Max keys per single shard request."
        },
        "servers": {
          "type": "array",
          "minItems": 1,
          "description": "Distributed shard endpoint list.",
          "items": {
            "$ref": "#/$defs/serverNode"
          }
        }
      }
    },
    "client": {
      "type": "object",
      "description": "Single-node client target server.",
      "additionalProperties": true,
      "required": [
        "host",
        "port",
        "shard"
      ],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1,
          "description": "Target host."
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Target port."
        },
        "shard": {
          "type": "integer",
          "minimum": 0,
          "description": "Target shard id."
        }
      }
    },
    "report_API": {
      "type": "string",
      "pattern": "^https?://.+",
      "default": "http://127.0.0.1:8081/report",
      "description": "HTTP endpoint for async report() ingestion service (typically writes to ClickHouse for Grafana dashboards)."
    },
    "hugectr": {
      "type": "object",
      "description": "HugeCTR frontend runtime backend selection.",
      "additionalProperties": true,
      "properties": {
        "backend": {
          "type": "string",
          "enum": [
            "recstore",
            "hierkv"
          ],
          "description": "HugeCTR runtime backend choice."
        }
      }
    },
    "hierkv": {
      "type": "object",
      "description": "HugeCTR HierarchicalKV backend configuration.",
      "additionalProperties": true,
      "properties": {
        "max_capacity": {
          "type": "integer",
          "minimum": 1
        },
        "max_hbm_for_vectors": {
          "type": "integer",
          "minimum": 0
        },
        "dim": {
          "type": "integer",
          "minimum": 1
        },
        "device_id": {
          "type": "integer"
        },
        "reserved_key_start_bit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 62
        }
      }
    }
  },
  "$defs": {
    "serverNode": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "host",
        "port",
        "shard"
      ],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1,
          "description": "Server host/IP."
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "description": "Server port."
        },
        "shard": {
          "type": "integer",
          "minimum": 0,
          "description": "Shard index for this node."
        }
      }
    },
    "baseKvConfig": {
      "type": "object",
      "description": "Underlying KV engine config.",
      "additionalProperties": true,
      "required": [
        "capacity",
        "index",
        "value"
      ],
      "properties": {
        "capacity": {
          "type": "integer",
          "minimum": 1
        },
        "index": {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "DRAM_EXTENDIBLE_HASH",
                "DRAM_UNORDERED_MAP",
                "DRAM_PET_HASH"
              ]
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "io": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "queue_depth": {
                  "type": "integer",
                  "minimum": 1
                },
                "base_offset_bytes": {
                  "type": "integer",
                  "minimum": 0
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "value": {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "DRAM_VALUE_STORE",
                "SSD_VALUE_STORE",
                "TIERED_VALUE_STORE"
              ]
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "default_value_size_hint": {
              "type": "integer",
              "minimum": 1
            },
            "dram_allocator": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "capacity_bytes": {
                  "type": "integer",
                  "minimum": 1
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            },
            "ssd_allocator": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string"
                },
                "capacity_bytes": {
                  "type": "integer",
                  "minimum": 1
                },
                "min_block_size": {
                  "type": "integer",
                  "minimum": 1
                },
                "max_block_size": {
                  "type": "integer",
                  "minimum": 1
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "io": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string"
                    },
                    "queue_depth": {
                      "type": "integer",
                      "minimum": 1
                    },
                    "base_offset_bytes": {
                      "type": "integer",
                      "minimum": 0
                    }
                  },
                  "additionalProperties": true
                }
              },
              "additionalProperties": true
            },
            "tiering": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": true,
          "allOf": [
            {
              "if": {
                "properties": {
                  "type": {
                    "const": "DRAM_VALUE_STORE"
                  }
                },
                "required": [
                  "type"
                ]
              },
              "then": {
                "required": [
                  "path",
                  "dram_allocator"
                ]
              }
            },
            {
              "if": {
                "properties": {
                  "type": {
                    "const": "SSD_VALUE_STORE"
                  }
                },
                "required": [
                  "type"
                ]
              },
              "then": {
                "required": [
                  "path",
                  "ssd_allocator"
                ]
              }
            },
            {
              "if": {
                "properties": {
                  "type": {
                    "const": "TIERED_VALUE_STORE"
                  }
                },
                "required": [
                  "type"
                ]
              },
              "then": {
                "required": [
                  "dram_allocator",
                  "ssd_allocator"
                ]
              }
            }
          ]
        }
      }
    }
  }
}
