{
  "cache_ps": {
    "ps_type": "BRPC",
    "max_batch_keys_size": 65536,
    "num_threads": 32,
    "num_shards": 2,
    "servers": [
      {
        "host": "127.0.0.1",
        "port": 25000,
        "shard": 0
      },
      {
        "host": "127.0.0.1",
        "port": 25001,
        "shard": 1
      }
    ],
    "base_kv_config": {
      "capacity": 1000000,
      "index": {
        "type": "DRAM_EXTENDIBLE_HASH"
      },
      "value": {
        "type": "DRAM_VALUE_STORE",
        "default_value_size_hint": 512,
        "dram_allocator": {
          "type": "PERSIST_LOOP_SLAB",
          "capacity_bytes": 512000000
        },
        "path": "/tmp/recstore_data_brpc/value"
      }
    }
  },
  "distributed_client": {
    "num_shards": 2,
    "hash_method": "city_hash",
    "max_keys_per_request": 500,
    "servers": [
      {
        "host": "127.0.0.1",
        "port": 25000,
        "shard": 0
      },
      {
        "host": "127.0.0.1",
        "port": 25001,
        "shard": 1
      }
    ]
  },
  "client": {
    "host": "127.0.0.1",
    "port": 25000,
    "shard": 0
  }
}
