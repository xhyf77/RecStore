SingleDayLaunchConfig.epochs = 1
SingleDayLaunchConfig.enable_prefetch = True
SingleDayLaunchConfig.prefetch_depth = 2
SingleDayLaunchConfig.fuse_emb_tables = True
SingleDayLaunchConfig.fuse_k = 30
SingleDayLaunchConfig.trace_file = ""
SingleDayLaunchConfig.allow_tf32 = False
SingleDayLaunchConfig.embedding_storage = "hbm"
