SingleDayLaunchConfig.use_torchrec = False
SingleDayLaunchConfig.use_random_dataset = True
SingleDayLaunchConfig.dataset_size = 65536
SingleDayLaunchConfig.processed_dataset_path = "./processed_day_0_data"
SingleDayLaunchConfig.batch_size = 1024
